# --- Database (auto-filled by Vercel when you connect a Postgres/Neon database) ---
DATABASE_URL=

# --- Auth ---
# A long random string used to sign owner login sessions. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# --- Telegram notifications ---
# Create a bot via @BotFather on Telegram to get a token, then message your
# bot once and visit https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Frontend (only needed if running the API on a different host than the frontend) ---
# Leave blank to use relative /api paths, which is correct for Vercel.
VITE_API_URL=
